# API Keys for Image Generation
# Отримайте ключі з відповідних сервісів та перейменуйте цей файл на .env

# Nano Banana Pro API Key
# https://nano-banana.pro/api
NANO_BANANA_API_KEY=your-nano-banana-pro-api-key-here

# Recraft AI API Key  
# https://recraft.ai/api
RECRAFT_API_KEY=your-recraft-api-key-here

# Google Gemini API Key
# https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Cloud Function Proxy (to bypass geo-blocking)
# Deploy using cloud-functions/gemini-proxy/deploy.sh
GEMINI_PROXY_URL=https://us-central1-your-project.cloudfunctions.net/gemini-proxy
GEMINI_PROXY_SECRET=your-secure-secret-key
GEMINI_PROXY_ENABLED=true