{
  "name": "dewclawbot-prompter",
  "version": "1.0.0",
  "description": "Automated creative prompt generator for gambling/traffic arbitrage creatives",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "generate": "ts-node src/generator/cli.ts",
    "generate:batch": "ts-node src/generator/cli.ts batch",
    "generate:check": "ts-node src/generator/cli.ts check-api"
  },
  "keywords": [
    "prompts",
    "creative",
    "gambling",
    "traffic-arbitrage",
    "image-generation",
    "localization"
  ],
  "author": "Max",
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/maxxxximus/dewclawbot.git"
  }
}
